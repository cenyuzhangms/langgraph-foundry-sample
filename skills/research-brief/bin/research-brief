#!/usr/bin/env python3
"""research-brief — render a one-page research brief Markdown to stdout.

Usage:
    research-brief "<topic>" [--findings findings.txt] [--sources sources.txt]

Both files are optional UTF-8 files with one bullet per line. Missing
sections are emitted as `<TODO: ...>` placeholders so the caller can fill
them in.
"""

from __future__ import annotations

import argparse
import datetime as dt
import sys
from pathlib import Path


def _read_lines(path: str | None) -> list[str]:
    if not path:
        return []
    p = Path(path)
    if not p.is_file():
        return []
    return [ln.strip(" -•\t") for ln in p.read_text(encoding="utf-8").splitlines() if ln.strip()]


def main() -> int:
    parser = argparse.ArgumentParser(description="Render a research brief Markdown.")
    parser.add_argument("topic", help="Topic of the brief, e.g. 'state of WebGPU 2026'.")
    parser.add_argument("--findings", help="Path to a text file of finding bullets.")
    parser.add_argument("--sources", help="Path to a text file of source URLs.")
    args = parser.parse_args()

    findings = _read_lines(args.findings) or ["<TODO: at least 3 concrete findings>"]
    sources = _read_lines(args.sources) or ["<TODO: list URLs the research used>"]

    today = dt.date.today().isoformat()
    md = [
        f"# Research brief: {args.topic}",
        f"_Compiled {today}_",
        "",
        "## Summary",
        "<TODO: one-sentence summary of what the research concluded.>",
        "",
        "## Key findings",
        *(f"- {f}" for f in findings),
        "",
        "## What we still don't know",
        "- <TODO: open questions worth a follow-up.>",
        "",
        "## Sources",
        *(f"- {s}" for s in sources),
        "",
    ]
    sys.stdout.write("\n".join(md))
    return 0


if __name__ == "__main__":
    sys.exit(main())
