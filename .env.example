# Foundry project endpoint (services.ai.azure.com URL — NOT the openai endpoint).
PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>

# Azure OpenAI endpoint of the same Foundry account; used by langchain-openai's
# AzureChatOpenAI to talk to the deployed chat model. Foundry derives this
# automatically; for local runs set it to https://<account>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://<your-foundry-account>.openai.azure.com/

MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-10-21
WORKDIR=/work
